{
  "manifest_version": 3,
  "name": "Agente RYR V14.6",
  "version": "14.6",
  "description": "Matriz Cognitiva Multi-Agente (Auto-Lore y Extracción Dual)",
  "permissions": ["storage", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.talkytimes.com/*"],
      "js": ["content.js"]
    }
  ],
  "host_permissions": ["http://10.21.41.168/*"]
}